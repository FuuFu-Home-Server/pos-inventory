# ─── Web App (main branch) ────────────────────────────────────────────────────

DATABASE_URL="postgresql://user:password@host:5432/kasir"
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Static QRIS string — paste your merchant QR payload here
NEXT_PUBLIC_QRIS_STRING=""

# ─── Desktop App (electron branch) ───────────────────────────────────────────

# SQLite is managed automatically by Electron at runtime.
# DATABASE_URL is injected by electron/main.ts → file:<userData>/kasir.db
# Do NOT set DATABASE_URL here when running electron:dev — it is overridden.

# For running Next.js standalone without Electron (e.g. remote Docker server):
# DATABASE_URL="file:./kasir.db"

# URL of the remote Tailscale server for sync (set inside the app UI, not here).
# Used only when building/testing the sync service directly:
# UPDATE_SERVER_URL="https://kasir.your-tailnet.ts.net"

# ─── Server Mode (PostgreSQL sync target for Electron clients) ────────────────

# IS_PROD_SERVER=true
# DATABASE_URL="postgresql://user:password@host:5432/kasir"
#
# Build:  npm run build:server   (swaps schema → PostgreSQL, generates client, builds)
# Deploy: prisma migrate deploy --schema=prisma/schema.postgresql.prisma
# Start:  IS_PROD_SERVER=true npm start
