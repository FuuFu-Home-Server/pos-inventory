{
  "name": "kasir",
  "version": "0.1.0",
  "description": "POS & Inventori untuk toko kelontong",
  "author": "Muhammad Irfan Jauhari",
  "private": true,
  "main": "electron-dist/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky",
    "electron:dev": "tsc --project electron/tsconfig.json && concurrently -k \"cross-env ELECTRON_DEV=true next dev\" \"tsc --project electron/tsconfig.json --watch --preserveWatchOutput\" \"wait-on http://localhost:3000 --timeout 30000 && ELECTRON_DEV=true ELECTRON_APP_ROOT=$PWD electron . --ozone-platform=x11 --disable-gpu\"",
    "electron:build": "next build && tsc --project electron/tsconfig.json && electron-builder",
    "electron:pack": "electron-builder --dir"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md}": "prettier --write"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.16.0",
    "next": "15.3.2",
    "next-auth": "beta",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.8.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "15.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.2",
    "wait-on": "^9.0.10"
  }
}
