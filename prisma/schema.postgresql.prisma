generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id                  Int             @id @default(autoincrement())
  name                String
  email               String          @unique
  passwordHash        String
  roleId              Int
  isActive            Boolean         @default(true)
  isDefaultCredential Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  role                Role            @relation(fields: [roleId], references: [id])
  transactions        Transaction[]
  purchaseOrders      PurchaseOrder[]
  stockOpnames        StockOpname[]
  importLogs          ImportLog[]
}

model Supplier {
  id             Int             @id @default(autoincrement())
  name           String
  phone          String?
  address        String?
  contactPerson  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  products       Product[]
  purchaseOrders PurchaseOrder[]
}

model Customer {
  id           Int           @id @default(autoincrement())
  name         String
  phone        String?       @unique
  address      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model CategoryOption {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)
}

model UnitOption {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  isActive Boolean @default(true)
}

model Product {
  id         Int              @id @default(autoincrement())
  name       String
  category   String
  supplierId Int?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  supplier   Supplier?        @relation(fields: [supplierId], references: [id])
  variants   ProductVariant[]
  discounts  Discount[]

  @@index([name])
  @@index([category])
}

model ProductVariant {
  id                 Int                 @id @default(autoincrement())
  productId          Int
  variantName        String
  barcode            String?             @unique
  price              Decimal             @db.Decimal(12, 2)
  costPrice          Decimal?            @db.Decimal(12, 2)
  stock              Int                 @default(0)
  lowStockThreshold  Int                 @default(5)
  unit               String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  product            Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  transactionItems   TransactionItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockOpnameItems   StockOpnameItem[]
  purchaseListItems  PurchaseListItem[]

  @@index([productId])
  @@index([isActive])
  @@index([isActive, stock])
}

model PaymentMethod {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  isActive     Boolean       @default(true)
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model Discount {
  id          Int           @id @default(autoincrement())
  name        String
  type        String
  value       Decimal       @db.Decimal(12, 2)
  scope       String
  productId   Int?
  minPurchase Decimal?      @db.Decimal(12, 2)
  isActive    Boolean       @default(true)
  validFrom   DateTime?
  validUntil  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  product     Product?      @relation(fields: [productId], references: [id])
  transactions Transaction[]

  @@index([scope, productId])
}

model Transaction {
  id              Int      @id @default(autoincrement())
  userId          Int
  customerId      Int?
  discountId      Int?
  paymentMethodId Int
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  subtotal        Decimal  @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  paymentAmount   Decimal  @db.Decimal(12, 2)
  changeAmount    Decimal  @default(0) @db.Decimal(12, 2)
  midtransOrderId String?  @unique
  status          String   @default("PENDING")
  syncStatus      String   @default("SYNCED")
  syncFailReason  String?
  localId         String?  @unique
  createdAt       DateTime @default(now())
  user            User              @relation(fields: [userId], references: [id])
  customer        Customer?         @relation(fields: [customerId], references: [id])
  discount        Discount?         @relation(fields: [discountId], references: [id])
  paymentMethod   PaymentMethod     @relation(fields: [paymentMethodId], references: [id])
  items           TransactionItem[]

  @@index([createdAt])
  @@index([userId])
  @@index([syncStatus])
}

model TransactionItem {
  id               Int            @id @default(autoincrement())
  transactionId    Int
  productVariantId Int
  qty              Int
  unitPrice        Decimal        @db.Decimal(12, 2)
  itemDiscountAmt  Decimal        @default(0) @db.Decimal(12, 2)
  subtotal         Decimal        @db.Decimal(12, 2)
  transaction      Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([transactionId])
}

model PurchaseOrder {
  id         Int      @id @default(autoincrement())
  supplierId Int?
  userId     Int
  status     String   @default("DRAFT")
  notes      String?
  createdAt  DateTime @default(now())
  receivedAt DateTime?
  syncStatus String   @default("PENDING")
  localId    String?  @unique
  supplier   Supplier?           @relation(fields: [supplierId], references: [id])
  user       User                @relation(fields: [userId], references: [id])
  items      PurchaseOrderItem[]

  @@index([status, createdAt])
  @@index([syncStatus])
}

model PurchaseOrderItem {
  id               Int            @id @default(autoincrement())
  purchaseOrderId  Int
  productVariantId Int
  qty              Int
  unitCost         Decimal        @db.Decimal(12, 2)
  subtotal         Decimal        @db.Decimal(12, 2)
  purchaseOrder    PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

model PurchaseList {
  id        Int      @id @default(autoincrement())
  title     String
  notes     String?
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
  items     PurchaseListItem[]
}

model PurchaseListItem {
  id               Int              @id @default(autoincrement())
  purchaseListId   Int
  productVariantId Int?
  productName      String
  variantName      String
  unit             String
  qty              Int
  qtyPerUnit       Int              @default(1)
  unitCost         Decimal          @db.Decimal(12, 2)
  isPurchased      Boolean          @default(false)
  purchaseList     PurchaseList     @relation(fields: [purchaseListId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant?  @relation(fields: [productVariantId], references: [id])
}

model StockOpname {
  id        Int      @id @default(autoincrement())
  userId    Int
  status    String   @default("DRAFT")
  notes     String?
  createdAt DateTime @default(now())
  user      User              @relation(fields: [userId], references: [id])
  items     StockOpnameItem[]
}

model StockOpnameItem {
  id               Int            @id @default(autoincrement())
  opnameId         Int
  productVariantId Int
  systemQty        Int
  physicalQty      Int            @default(0)
  difference       Int            @default(0)
  opname           StockOpname    @relation(fields: [opnameId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

model ReceiptConfig {
  id               Int      @id @default(1)
  storeName        String   @default("Toko Saya")
  address          String?
  phone            String?
  headerText       String?
  footerText       String?
  showTax          Boolean  @default(false)
  showCashier      Boolean  @default(true)
  paperWidth       Int      @default(80)
  staticQrisImage  String?
  updatedAt        DateTime @updatedAt
}

model ImportLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  filename        String
  recordsImported Int      @default(0)
  status          String   @default("PENDING")
  errorMessage    String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])
}

model SyncMeta {
  storeName  String    @id
  lastSyncAt DateTime?
}
